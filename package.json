{
  "name": "chengpeiquan.com",
  "version": "2.0.0",
  "type": "module",
  "packageManager": "pnpm@10.15.1",
  "private": true,
  "scripts": {
    "dev": "run-s dev:*",
    "dev:cache": "pnpm run build:cache",
    "dev:thumb-hash": "pnpm run build:thumb-hash",
    "dev:app": "next dev -p 4832",
    "build": "run-s build:*",
    "build:cache": "tsx ./scripts/generate-cache.ts",
    "build:thumb-hash": "tsx ./scripts/generate-thumb-hash.ts",
    "build:app": "next build --webpack",
    "build:copy-assets": "tsx ./scripts/copy-assets.ts",
    "preview": "docker-compose build && docker-compose up -d",
    "start": "next start",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "run-s lint:*",
    "lint:oxlint": "oxlint .",
    "lint:eslint": "pnpm exec eslint .",
    "format": "oxfmt .",
    "format:check": "oxfmt . --check",
    "format:prettier": "prettier --write .",
    "backup": "git add . && git commit -m \"chore: backup\" && git push",
    "deps:check": "pnpm exec taze major",
    "deps:up": "pnpm exec taze -w -i",
    "prepare": "husky"
  },
  "dependencies": {
    "@bassist/utils": "^0.17.0",
    "@re-dev/react-truncate": "^0.6.0",
    "@web-analytics/core": "^0.1.5",
    "blackwork": "^0.9.0",
    "flexsearch": "^0.7.43",
    "framer-motion": "^12.38.0",
    "next": "^16.2.2",
    "next-intl": "^4.9.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-forage": "^0.2.2",
    "react-ga4": "^2.1.0",
    "thumbhash": "^0.1.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@bassist/eslint-config": "^0.4.1",
    "@bassist/node-utils": "^0.5.0",
    "@bassist/oxc-integration": "^0.1.4",
    "@bassist/tsconfig": "^0.1.1",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@shikijs/rehype": "^4.0.2",
    "@stefanprobst/rehype-extract-toc": "^3.0.0",
    "@tailwindcss/typography": "^0.5.19",
    "@types/hast": "^3.0.4",
    "@types/mdast": "^4.0.4",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "eslint": "^9.39.4",
    "feed": "^4.2.2",
    "gray-matter": "^4.0.3",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "npm-run-all2": "^8.0.4",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.59.0",
    "oxlint-tsgolint": "^0.20.0",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-external-links": "^3.0.0",
    "rehype-react": "^8.0.0",
    "rehype-sanitize": "^6.0.0",
    "rehype-slug": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "rehype-unwrap-images": "^1.0.0",
    "remark-directive": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "remark-stringify": "^11.0.0",
    "sharp": "^0.34.5",
    "tailwind-merge": "^2.6.1",
    "tailwindcss": "^3.4.19",
    "tailwindcss-animate": "^1.0.7",
    "taze": "^19.11.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0",
    "vitest": "^4.0.7"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "oxfmt --write",
      "oxlint --fix",
      "pnpm exec eslint --fix"
    ],
    "*.md": [
      "prettier --write"
    ]
  }
}
