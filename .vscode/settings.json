{
  "cSpell.words": [
    "analyticsjs",
    "bento",
    "blackwork",
    "bunx",
    "clsx",
    "cnzz",
    "commitlint",
    "Darkglass",
    "Discuz",
    "flexsearch",
    "Gtag",
    "Ibanez",
    "jing",
    "jingzizhong",
    "jsxs",
    "Marzio",
    "mdast",
    "netease",
    "npmjs",
    "oxfmt",
    "Oxlint",
    "Pageview",
    "Peiquan",
    "Pinia",
    "Pluggable",
    "POPO",
    "Porkbun",
    "prebuild",
    "Rehype",
    "rehypejs",
    "Remarkjs",
    "Riko",
    "Shiki",
    "shikijs",
    "stefanprobst",
    "Sweetlemos",
    "tailwindcss",
    "taze",
    "Teochew",
    "thumbhash",
    "tsgolint",
    "Unifiedjs",
    "unoptimized",
    "vfile",
    "VXNA",
    "xiaohongshu",
    "zhihu",
    "zhong"
  ],
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "always",
    "source.fixAll.oxc": "always",
    "source.fixAll.prettier": "always"
  },
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.formatOnSave": true,
  "eslint.format.enable": true,
  "eslint.useFlatConfig": true,
  "eslint.validate": [
    "javascript",
    "javascriptreact",
    "typescript",
    "typescriptreact",
    "json",
    "jsonc"
  ],
  "explorer.fileNesting.enabled": true,
  "explorer.fileNesting.patterns": {
    ".env": ".env.*",
    "Dockerfile": "Dockerfile, docker-compose*, .dockerignore",
    "package.json": "bun.lock*, .eslint*, eslint*, .oxlint*, oxlint*, oxfmt*, oxfmt*, .prettier*, .editorconfig, postcss.config*, tailwind.config.ts, tailwind.whitelist.js, commitlint.config.js, next.config*, tsconfig.json, .gitignore, .swcrc, LICENSE, AGENTS.md, CLAUDE.md",
    "tsconfig.json": "tsconfig.*.json, env.d.ts",
    "vite.config.*": "jsconfig*, vitest.config.*, cypress.config.*, playwright.config.*"
  },
  "i18n-ally.localesPaths": ["src/i18n", "src/i18n/messages"],
  "oxc.typeAware": true,
  "prettier.configPath": "./.prettierrc.js"
}
